# Backend API environment template
# Copy this file to `.env` and update values for your environment.

CI_ENVIRONMENT = development
app.local.baseURL = 'http://127.0.0.1/khaitan_dev_new/backend/public/'
app.production.baseURL = 'https://admin.khaitan.com/'
app.baseURL = 'http://127.0.0.1/khaitan_dev_new/backend/public/'

# Local development database (used when CI_ENVIRONMENT is not production)
database.local.hostname = 127.0.0.1
database.local.database = your_local_database_name
database.local.username = root
database.local.password =
database.local.DBDriver = MySQLi
database.local.DBPrefix =
database.local.port = 3306
database.local.charset = utf8mb4
database.local.DBCollat = utf8mb4_general_ci

# Production database (used when CI_ENVIRONMENT = production)
database.production.hostname = localhost
database.production.database = your_production_database_name
database.production.username = your_production_database_user
database.production.password = your_production_database_password
database.production.DBDriver = MySQLi
database.production.DBPrefix =
database.production.port = 3306
database.production.charset = utf8mb4
database.production.DBCollat = utf8mb4_general_ci
