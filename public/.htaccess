# Disable directory browsing
Options -Indexes

# CORS is handled by CodeIgniter Filters (Config\Cors + Config\Domains).
# Duplicate Apache Header entries would conflict when both layers run.

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# Base path intentionally omitted so this works in both
	# local (/khaitan_dev_new/khaitan_api/public) and production
	# (/khaitan_api/public) without editing per environment.

	# Redirect Trailing Slashes
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Pass Authorization and Access-Token to PHP before front controller ([L] on index stops later rules).
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
	RewriteCond %{HTTP:Access-Token} .
	RewriteRule .* - [E=HTTP_ACCESS_TOKEN:%{HTTP:Access-Token}]

	# Route all requests (including OPTIONS preflight) to index.php so CI Cors filter can respond.
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]
</IfModule>

<IfModule !mod_rewrite.c>
	ErrorDocument 404 index.php
</IfModule>

# Disable server signature
ServerSignature Off
